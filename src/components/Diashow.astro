---
import "../styles/global.css";

const {
  slides = [
    {
      image: "/imgs/hero.png",
      imageAlt: "Hero 1",
      objectPosition: "50% 40%",
      title: `Create. Select.<br>&nbsp;&nbsp;&nbsp;&nbsp;Experience.<br><span>- Live mit KI</span>`,
      name: `AI-<span>Verse</span>`,
      lede: `Schon überlegt, wie du & dein Produkt in <strong>einer neuen Dimension</strong> wirken?`,
      ledeBottom: ""
    },
    {
      image: "/imgs/dia/cityex.png",
      imageAlt: "Hero 1",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span> - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/fan.png",
      imageAlt: "Hero 2",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span> - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/food.png",
      imageAlt: "Hero 3",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span> - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/marken.png",
      imageAlt: "Hero 4",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span>  - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/Messen.png",
      imageAlt: "Hero 5",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span>  - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/Museen.png",
      imageAlt: "Hero 6",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span>  - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/retailStore.png",
      imageAlt: "Hero 7",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span>  - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/shopping_mall.png",
      imageAlt: "Hero 8",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span>  - Live mit KI</span>`
    },
    {
      image: "/imgs/dia/wedding.png",
      imageAlt: "Hero 9",
      objectPosition: "50% 40%",
      title: ``,
      name: ``,
      lede: ``,
      ledeBottom: `Create. Select. Experience.<span>  - Live mit KI</span>`
    },
  ],
  interval = 4500
} = Astro.props;
---

<section class="hero-slideshow" data-interval={interval}>
  <div class="hero-slideshow_slides">
    {slides.map((slide, i) => (
      <article
        class={`hero-slide ${i === 0 ? "is-active" : ""}`}
        data-slide
        aria-hidden={i === 0 ? "false" : "true"}
      >
        <img
          src={slide.image}
          alt={slide.imageAlt}
          class="hero-slide_img"
          style={`object-position:${slide.objectPosition || "50% 50%"}`}
        />

        <div class="hero-slide_overlay">
          <div class="hero-title">
            <h1>
              <Fragment set:html={slide.title.replace(
                "<span>",
                `<span style="font-family: Unigeo slim;">`
              )} />
            </h1>
          </div>

          <div class="name-title">
            <h1 style="font-family: Unigeo slim;">
              <Fragment set:html={slide.name.replace(
                "<span>",
                `<span style="font-family: Unigeo semibold;">`
              )} />
            </h1>


            <div class="lede">
              <Fragment set:html={slide.lede} />
            </div>
          </div>

          <div class="lede-bottom">
            <Fragment set:html={slide.ledeBottom} />
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  const slideshows = document.querySelectorAll(".hero-slideshow");

  slideshows.forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const slides = Array.from(
      root.querySelectorAll<HTMLElement>("[data-slide]")
    );

    const interval = Number(root.dataset.interval || 4500);

    if (slides.length <= 1) return;

    let index = 0;

    const showSlide = (nextIndex) => {
      slides.forEach((slide, i) => {
        const active = i === nextIndex;
        slide.classList.toggle("is-active", active);
        slide.setAttribute("aria-hidden", active ? "false" : "true");
      });
    };

    setInterval(() => {
      index = (index + 1) % slides.length;
      showSlide(index);
    }, interval);
  });
</script>

<style>
  .hero-slideshow {
    position: relative;
    min-height: 90vh;
    overflow: hidden;
  }

  .hero-slideshow_slides {
    position: relative;
    min-height: 90vh;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 900ms ease;
    pointer-events: none;
  }

  .hero-slide.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 1;
  }

  .hero-slide_img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-slide_overlay {
    position: relative;
    z-index: 2;
    min-height: 90vh;
  }

  .lede-bottom{
    position:absolute;
    bottom:40px;
    left:50%;
    transform:translateX(-50%);
    
    font-family:"Unigeo semibold";
    text-align:center;
    font-size:25px;
    letter-spacing: 0.05em;
    color:white;

    max-width:600px;
    padding:0 20px;
    }

    .lede-bottom :global(span){
    font-family:"Unigeo slim";
    }

  .hero-slide .lede-bottom{
    opacity:0;
    transform:translate(-50%,10px);
    transition: all .8s ease;
    }

  .hero-slide.is-active .lede-bottom{
    opacity:1;
    transform:translate(-50%,0);
    }

  @media (max-width: 700px) {
    .hero-slideshow,
    .hero-slideshow_slides,
    .hero-slide_overlay {
      min-height: 82vh;
    }
    .lede-bottom{
        font-size: 16px;
    }
  }
</style>