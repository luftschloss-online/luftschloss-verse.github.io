---
import '../styles/global.css';

type Slide = {
  img: string;
  alt?: string;
  title1: string;
  title2: string;
  text: string;
};

const {
  slides = [] as Slide[],
  interval = 1000,
  startIndex = 0,
} = Astro.props;

const safeStart = Math.min(Math.max(startIndex, 0), Math.max(slides.length - 1, 0));
---

{slides.length > 0 && (
  <section
    class="ss"
    data-slideshow
    data-interval={interval}
    data-start={safeStart}
    aria-roledescription="carousel"
  >
    <header class="ss_head">
      <slot name="headline" />
    </header>

    <div class="ss_stage" tabindex="0">
      <button class="ss_btn ss_btn--prev" type="button" data-prev aria-label="Previous slide">
        ‹
      </button>

      <div class="ss_viewport">
        {slides.map((s, i) => (
           <article
            class="ss_slide"
            data-slide
            data-index={i}
            data-pos="999"
            aria-hidden="true"
            >
            <div class="ss_card">
                <img class="ss_img" src={s.img} alt={s.alt ?? ""} loading="lazy" />
            </div>

            <div class="ss_text">
                <h3 class="ss_title"><span style="font-weight: 200; font-style: Italic;">{s.title1}</span>{s.title2}</h3>
                <p class="ss_copy">{s.text}</p>
            </div>
            </article>
        ))}
      </div>

      <button class="ss_btn ss_btn--next" type="button" data-next aria-label="Next slide">
        ›
      </button>
    </div>

    <div class="ss_dots" aria-label="Slide navigation">
      {slides.map((_, i) => (
        <button
          class="ss_dot"
          type="button"
          data-dot
          data-goto={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
    <script is:inline>
    (() => {
        const root = document.currentScript?.closest("[data-slideshow]");
        if (!root) return;

        const intervalMs = Number(root.getAttribute("data-interval")) || 4500;
        const start = Number(root.getAttribute("data-start")) || 0;

        const slides = Array.from(root.querySelectorAll("[data-slide]"));
        const dots = Array.from(root.querySelectorAll("[data-dot]"));
        const prevBtn = root.querySelector("[data-prev]");
        const nextBtn = root.querySelector("[data-next]");
        const stage = root.querySelector(".ss_stage");

        let index = Math.min(Math.max(start, 0), slides.length - 1);
        let timer = null;
        let paused = false;

        function render() {
            const len = slides.length;

            const prevIndex = (index - 1 + len) % len;
            const nextIndex = (index + 1) % len;

            slides.forEach((el, i) => {
                let pos = 999;
                if (i === index) pos = 0;
                else if (i === prevIndex) pos = -1;
                else if (i === nextIndex) pos = 1;

                el.dataset.pos = String(pos);

                const isVisible = pos !== 999;
                el.setAttribute("aria-hidden", i === index ? "false" : "true");

                const img = el.querySelector("img");
                if (img) img.loading = (pos === 0 ? "eager" : "lazy");
            });

            dots.forEach((d, i) => d.classList.toggle("is-active", i === index));
            }

        function goTo(i) { index = (i + slides.length) % slides.length; render(); }
        function next() { goTo(index + 1); }
        function prev() { goTo(index - 1); }

        function stop() { if (timer) { clearInterval(timer); timer = null; } }
        function play() {
            stop();
            if (intervalMs > 0 && slides.length > 1 && !paused) timer = setInterval(next, intervalMs);
        }

        prevBtn?.addEventListener("click", () => { prev(); play(); });
        nextBtn?.addEventListener("click", () => { next(); play(); });

        dots.forEach((d) => d.addEventListener("click", () => {
            goTo(Number(d.getAttribute("data-goto")));
            play();
        }));

        stage?.addEventListener("keydown", (e) => {
            if (e.key === "ArrowLeft") { e.preventDefault(); prev(); play(); }
            if (e.key === "ArrowRight") { e.preventDefault(); next(); play(); }
        });

        const pauseOn = () => { paused = true; stop(); };
        const pauseOff = () => { paused = false; play(); };

        root.addEventListener("mouseenter", pauseOn);
        root.addEventListener("mouseleave", pauseOff);
        root.addEventListener("focusin", pauseOn);
        root.addEventListener("focusout", pauseOff);

        // init
        render();
        play();
        slides.forEach((el) => {
        el.addEventListener("click", () => {
            const pos = Number(el.dataset.pos);
            if (pos === -1) { prev(); play(); }
            if (pos === 1) { next(); play(); }
        });
        });
        })();
    </script>
  </section>
)}

<style>
  .ss { --phone-h: clamp(350px, 52vh, 550px);
  display:grid; gap: 12px; place-items:center; padding: 18px 0; }
  .ss_head { width: min(980px, 92vw); text-align:center; }

  .ss_stage{
    width:min(980px, 92vw);
    position:relative;
    outline:none;
    display:grid;
    place-items:center;
  }

  .ss_viewport{
    width:100%;
    position:relative;
    display:grid;
    place-items:center;
    min-height: calc(var(--phone-h) + 120px); 
    overflow: visible;
    }

.ss_slide{
  position:absolute;
  inset: 0;
  margin: auto;
  display:grid;
  justify-items:center;
  align-content:start;
  gap: 14px;

  opacity: 0;
  pointer-events: none;
  transform: translateX(0) scale(.9);
  transform-origin: center;
  transition: transform .32s ease, opacity .32s ease;
  z-index: 1;
}

.ss_slide[data-pos="0"]{
  opacity: 1;
  pointer-events: auto;
  transform: translateX(0) scale(1);
  z-index: 3;
}

.ss_slide[data-pos="-1"]{
  opacity: .55;
  pointer-events: auto;
  transform: translateX(-18%) scale(.62);
  z-index: 2;
}
.ss_slide[data-pos="1"]{
  opacity: .55;
  pointer-events: auto;
  transform: translateX(18%) scale(.62);
  z-index: 2;
}

  .ss_card{
    height: var(--phone-h);
    width: auto;
    aspect-ratio: 9 / 16;
    overflow:hidden;
    box-shadow: 0 10px 26px rgba(0,0,0,.08);
    background: rgba(0,0,0,.03);
    }
  .ss_img{ width:100%; height:100%; object-fit:contain; display:block; }

  .ss_text{ width:min(680px, 92vw); text-align:center; padding-top: 40px; }
  .ss_title{ margin:.25rem 0 .2rem; font-size: clamp(20px, 2.6vw, 30px); font-weight: 900; }
  .ss_copy{ margin:0; line-height:2; font-size: clamp(16px, 2.6vw, 20px); }

  .ss_btn{
    position:absolute;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
    width:40px;
    height:40px;
    cursor:pointer;
    color: var(--accent);
    font-size:80px;
    line-height: 0;
    display:grid;
    place-items:center;
  }
  .ss_btn:hover{ color:black; }
  .ss_btn--prev{ left: 8%; }
  .ss_btn--next{ right: 8%; }

  @media (max-width: 720px){
    .ss_btn--prev{ left: 6px; }
    .ss_btn--next{ right: 6px; }
  }

  .ss_dots{ display:flex; gap:8px; padding-top: 30px;}
  .ss_dot{
    width:9px; height:9px;
    border-radius:999px;
    border:0;
    background: rgba(0,0,0,.2);
    cursor:pointer;

    padding-top: 20px;
  }
  .ss_dot.is-active{ background: rgba(0,0,0,.55); }

.ss_slide[data-pos="-1"]{ transform: translateX(-20%) scale(.72); }
.ss_slide[data-pos="1"]{ transform: translateX(20%) scale(.72); }

.ss_img{ width:100%; height:100%; object-fit:contain; display:block; }

.ss_slide[data-pos="-1"] .ss_text,
.ss_slide[data-pos="1"] .ss_text{
  opacity: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}
</style>