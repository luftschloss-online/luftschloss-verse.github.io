---
import "../styles/global.css";
---

<section id="contact" class="cta-hero">
  <img class="cta-bg" src="imgs/footer-himmel.png" alt="" />

  <div class="cta-inner">
    <div class="cta-top">
      <div class="cta-copy">
        <h2>Lust auf eure eigene<br /></h2>
        <p>Signature Interactive<br />Experience?</p>
      </div>
    </div>

    <div class="cta-bottom">
      <div class="cta-circle">
        <span>
          Wir bauen <br />
          <b>euer Luftschloss</b> –<br />
          individuell und<br />
          effizient umgesetzt.
        </span>
      </div>
      <div class="cta-title">let’s talk</div>
    </div>

    <img class="cta-cloud" src="imgs/overlay_wolke.png" alt="">
  </div>
</section>

<style>
  .cta-hero{
    position: relative;
    overflow: hidden;
    min-height: 100svh;
    display: flex;
    align-items: stretch;
    isolation: isolate;
  }

  .cta-bg{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    z-index: 0;
  }

  .cta-cloud{
    position: absolute;
    left: 50%;
    transform: translateX(-50%);

    bottom: -15vw;

    width: 120vw;
    max-width: none;

    z-index: 3;
    pointer-events: none;
  }

  .cta-hero::after{
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.08);
    z-index: 1;
    pointer-events: none;
  }

  .cta-inner{
    position: relative;
    z-index: 2;
    width: min(1400px, 100%);
    margin: 0 auto;
    padding:
      clamp(28px, 4vw, 56px)
      clamp(18px, 3vw, 36px)
      clamp(18px, 2vw, 28px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100svh;
  }

  .cta-top{
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
      /* off state */
  opacity: 0;
  transform: translateY(22px) scale(.92);
  transition:
    opacity 700ms cubic-bezier(0,0,.58,1),
    transform 900ms cubic-bezier(0,0,.58,1);
  will-change: transform, opacity;
}

/* view state */
.cta-top.is-inview{
  opacity: 1;
  transform: translateY(0) scale(1);
}

  .cta-copy{
    max-width: 1000px;
    color: white;
  }

  .cta-copy h2{
    margin: 0;
    font-family: "Unigeo slim", sans-serif;
    font-size: clamp(60px, 5.6vw, 92px);
    line-height: 0.95;
    font-weight: 700;
  }

  .cta-copy p{
    margin: 6px 0 0;
    font-family: "Unigeo semibold", sans-serif;
    font-size: clamp(60px, 5.6vw, 92px);
    line-height: 0.95;
    color: rgba(255,255,255,0.96);
  }

  .cta-circle{
    position: absolute;
    right: clamp(2%, 12vw, 14%);
    bottom: 40%;
    width: clamp(250px, 16vw, 320px);
    aspect-ratio: 1;

    border-radius: 50%;
    background: rgba(255,255,255,0.9);

    display: grid;
    place-items: center;
    text-align: center;

    padding: clamp(18px, 2vw, 26px);
    /* off state */
  opacity: 0;
  transform: translateY(22px) scale(.92);
  transition:
    opacity 700ms cubic-bezier(0,0,.58,1),
    transform 900ms cubic-bezier(0,0,.58,1);
  will-change: transform, opacity;
}

/* view state */
.cta-circle.is-inview{
  opacity: 1;
  transform: translateY(0) scale(1);
}

  .cta-circle span{
    font-family: "Unigeo MediumItalic", sans-serif;
    font-size: clamp(18px, 1.8vw, 25px);
    line-height: 1.15;
    color: #3a3a3a;
  }

  .cta-circle b{
    letter-spacing: 0.04em;
  }

  .cta-bottom{
    display: flex;
    align-items: flex-end;
    justify-content: center;
    flex: 1;
}

  .cta-title{
    width: 100%;
    margin: 0;
    font-family: "Unigeo", sans-serif;
    color: #fff;
    opacity: 1;
    font-size: clamp(100px, 30vw, 380px);
    line-height: 0.82;
    text-align: center;
    white-space: nowrap;
    letter-spacing: -0.05em;
    /* off state */
    opacity: 0;
    transform: translateY(22px) scale(.92);
    transition:
      opacity 700ms cubic-bezier(0,0,.58,1),
      transform 900ms cubic-bezier(0,0,.58,1);
    will-change: transform, opacity;
}

/* view state */
.cta-title.is-inview{
  opacity: 1;
  transform: translateY(0) scale(1);
}

  @media (max-width: 900px){
    .cta-hero{ min-height: auto; }

    .cta-inner{
      min-height: auto;
      justify-content: flex-start;
      gap: 300px;
    }

    .cta-bottom{
      flex: 0 0 auto;
      justify-content: center;
      align-items: flex-end;
    }

    .cta-title{
      font-size: clamp(72px, 30vw, 220px);
      white-space: normal;
    }

    .cta-top{
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-circle{
      margin-left: auto;
      width: 250px;
      bottom: 30%;
    }
    .cta-circle span{ font-size: 24px;}
  }

  @media (max-width: 640px){
    .cta-inner{ gap: 200px;}
    .cta-copy h2{ font-size: clamp(32px, 8vw, 50px);}
    .cta-copy p{ font-size: clamp(32px, 8vw, 50px); }
    .cta-cloud{ bottom: -12vw; }

    .cta-circle{
      width: 170px;
      padding: 18px;
      bottom: 25%;
    }
    .cta-circle span{ font-size: 16px;}

    .cta-title{
      font-size: clamp(64px, 30vw, 130px);
      line-height: 0.9;
    }
  }
</style>