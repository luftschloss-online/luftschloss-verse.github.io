---
const { href = "/#" } = Astro.props;
import '../styles/global.css';
---
<header class="site-header">
  <div class="hdr_inner">
    <a class="brand" href={href} aria-label="Home">
      <span class="brand_ai">AI-</span><span class="brand_verse">Verse</span>
      <span class="brand_by">by</span>
      <span class="ls_logo">luftschloss.</span>
    </a>
  </div>
</header>

<style>
  .hdr_inner{
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 24px;
  }
</style>
