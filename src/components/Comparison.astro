---
import '../styles/global.css';

const {
  leftTitle = '"AI-Photobooth"',
  rightTitle = 'AI-Verse',
  beforeImage = '/imgs/compare2.png',
  afterImage = '/imgs/compare1.jpg',
  beforeAlt = 'Vorher',
  afterAlt = 'Nachher',
  leftPoints = [
    'Browser/Standard-Templates',
    'Wenig Branding',
    'Wartezeiten ohne Mehrwert',
    'Passive Nutzung',
    'Begrenzte Erlebnisqualität',
    'Zufällige Ergebnisse'
  ],
  rightPoints = [
    'Eigene App für Stabilität & Tempo',
    'Stele & UI im Brand-Design',
    'Wartezeit ist Teil der Experience',
    'Modular erweiterbar',
    'Konzept + Ästhetik aus einer Hand'
  ]
} = Astro.props;
---

<section class="compare-section">
  <div class="compare-wrap">
    <header class="compare-head">
      <h2>
        Not just A(I) Photobooth!
      </h2>
    </header>

    <div class="compare-layout">
      <aside class="rough-card rough-card-left">
        <h3>{leftTitle}</h3>
        <ul>
          {leftPoints.map((point) => <li>{point}</li>)}
        </ul>
      </aside>

      <div class="compare-center">
        <div class="compare-slider" data-compare-slider>
          <img
            src={beforeImage}
            alt={beforeAlt}
            class="compare-img compare-img-base"
            draggable="false"
          />

          <div class="compare-overlay" data-compare-overlay>
            <img
              src={afterImage}
              alt={afterAlt}
              class="compare-img compare-img-top"
              draggable="false"
            />
          </div>

          <div
            class="compare-handle"
            data-compare-handle
            role="slider"
            aria-label="Bildvergleich"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="50"
            tabindex="0"
          >
            <span class="compare-handle_line"></span>
            <span class="compare-handle_knob">↔</span>
          </div>
        </div>

      </div>

      <aside class="rough-card rough-card-right">
        <h3>{rightTitle}</h3>
        <ul>
          {rightPoints.map((point, i) => (
            <li class={i < 3 ? 'is-strong' : ''}>{point}</li>
          ))}
        </ul>
      </aside>

    </div>
    <div class="compare_brand">
      <div class="brand">
        <span class="brand_ai">AI-</span><span class="brand_verse">Verse</span>
        <span class="brand_by">by</span>
        <span class="ls_logo">luftschloss.</span>
      </div>
    </div>
  </div>
</section>

<script>
  const sliders = document.querySelectorAll<HTMLElement>('[data-compare-slider]');

  sliders.forEach((slider) => {
    const overlay = slider.querySelector<HTMLElement>('[data-compare-overlay]');
    const handle = slider.querySelector<HTMLElement>('[data-compare-handle]');
    if (!overlay || !handle) return;

    let isDragging = false;
    let current = 50;

    const setPosition = (percent: number) => {
      current = Math.max(0, Math.min(100, percent));
      overlay.style.clipPath = `inset(0 ${100 - current}% 0 0)`;
      handle.style.left = `${current}%`;
      handle.setAttribute('aria-valuenow', String(Math.round(current)));
    };

    const getPercentFromEvent = (clientX: number) => {
      const rect = slider.getBoundingClientRect();
      return ((clientX - rect.left) / rect.width) * 100;
    };

    const startDrag = (clientX: number) => {
      isDragging = true;
      setPosition(getPercentFromEvent(clientX));
    };

    const moveDrag = (clientX: number) => {
      if (!isDragging) return;
      setPosition(getPercentFromEvent(clientX));
    };

    const stopDrag = () => {
      isDragging = false;
    };

    slider.addEventListener('pointerdown', (e) => {
      startDrag(e.clientX);
    });

    window.addEventListener('pointermove', (e) => {
      moveDrag(e.clientX);
    });

    window.addEventListener('pointerup', stopDrag);
    window.addEventListener('pointercancel', stopDrag);

    handle.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        setPosition(current - 5);
      }
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        setPosition(current + 5);
      }
    });

    setPosition(50);
  });
</script>

<style>
  .compare-section {
    position: relative;
    background: #fff;
    padding: clamp(64px, 8vw, 110px) 20px;
    overflow: hidden;
  }

  .compare-wrap {
    width: min(1200px, 100%);
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .compare-head {
    text-align: center;
    margin-bottom: clamp(28px, 4vw, 48px);
  }

  .compare-head h2 {
    margin: 0;
    font-family: "Unigeo slimItalic", sans-serif;
    font-size: clamp(34px, 5vw, 66px);
    line-height: 0.8;
    font-weight: 400;
    color: #111;
  }

  .compare-head h2 span {
    display: block;
    font-family: "Bahnschrift", sans-serif;
    font-style: italic;
    font-weight: 800;
  }

  .compare-layout {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(280px, 420px) minmax(260px, 1fr);
    align-items: center;
    gap: clamp(18px, 3vw, 40px);
  }

  .rough-card {
    position: relative;
    min-height: 330px;
    padding: 42px 34px;
    border-radius: 40px;
    backdrop-filter: blur(2px);
  
    
        /* off state */
  opacity: 0;
  transform: translateY(22px) scale(.92);
  transition:
    opacity 700ms cubic-bezier(0,0,.58,1),
    transform 900ms cubic-bezier(0,0,.58,1);
  will-change: transform, opacity;
}

/* view state */
.rough-card.is-inview{
  opacity: 1;
  transform: translateY(0) scale(1);
}

  .rough-card-right{
    border: .15cap solid transparent;
    background:
      linear-gradient(white, white) padding-box,
      linear-gradient(200deg, #b9d0e5, #F4A3B4) border-box;
  }

  .rough-card-left{
    border: 1px solid rgba(0, 0, 0);
  }

  .rough-card h3 {
    margin: 0 0 28px;
    text-align: center;
    font-family: "Unigeo semibold Italic", sans-serif;
    font-size: clamp(28px, 2.2vw, 44px);
    line-height: 1;
    color: #1a1a1a;
  }

  .rough-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }

  .rough-card li {
    font-size: clamp(15px, 1.15vw, 18px);
    line-height: 1.25;
    color: rgba(17,17,17,.82);
    position: relative;
    padding-left: 1em;
  }

  .rough-card li::before{
    position: absolute;
    left: 0;
    top: 0;
    font-family: "Bahnschrift", sans-serif;
    font-weight: 700;
    line-height: 1.25;
}

  .rough-card-left li::before{
    content: ">";
    color: #111;
    font-size: 19px;
  }

  .rough-card-right li::before{
    content: ">";
    color: #a7b8c7;
    font-size: 19px;
  }

  .compare-center {
    position: relative;
    display: grid;
    gap: 12px;
    justify-items: center;
  }

  .compare-slider {
    position: relative;
    width: min(100%, 390px);
    aspect-ratio: 0.565 / 1;
    overflow: hidden;
    border-radius: 0;
    box-shadow:
      0 18px 40px rgba(0,0,0,.12),
      0 6px 16px rgba(0,0,0,.08);
    background: #ddd;
    touch-action: auto;
    user-select: none;
  }

  .compare-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }

  .compare-overlay {
    position: absolute;
    inset: 0;
    clip-path: inset(0 50% 0 0);
  }

  .compare-handle {
    position: absolute;
    top: 0;
    left: 50%;
    width: 44px;
    height: 100%;
    transform: translateX(-50%);
    display: grid;
    place-items: center;
    cursor: ew-resize;
    z-index: 3;
  }

  .compare-handle_line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: rgba(255,255,255,.95);
    box-shadow: 0 0 0 1px rgba(0,0,0,.12);
  }

  .compare-handle_knob {
    position: relative;
    z-index: 2;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: #79b7ff;
    color: white;
    font-size: 20px;
    line-height: 1;
    box-shadow: 0 10px 24px rgba(0,0,0,.18);
  }

  .compare-caption {
    width: min(100%, 390px);
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: rgba(17,17,17,.65);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .compare_brand {
    margin-top: clamp(28px, 4vw, 42px);
    text-align: center;
  }

  @media (max-width: 980px) {
    .compare-layout {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    .rough-card,
    .compare-center {
      width: min(100%, 560px);
    }

    .compare-center {
      order: 2;
    }

    .rough-card-left {
      order: 1;
    }

    .rough-card-right {
      order: 3;
    }
  }

  @media (max-width: 640px) {
    .compare-section {
      padding-inline: 14px;
    }

    .rough-card {
      min-height: auto;
      padding: 24px 24px;
      width: 70%;
    }

    .rough-card h3 {
      margin-bottom: 20px;
    }

    .compare-slider {
      width: min(100%, 320px);
    }

    .compare-caption {
      width: min(100%, 320px);
    }
  }
</style>