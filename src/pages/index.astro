---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlobMask from "../components/BlobMask.astro";
import CTA from "../components/CTA.astro";

import Slideshow from "../components/Slideshow.astro";
import Modules from "../components/Modules.astro";
import Comparison from "../components/Comparison.astro";
import Diashow from "../components/Diashow.astro";

const slides = [
  {
    img: "luftschloss-verse.github.io/imgs/choose.png",
    alt: "idle screen",
    title1: "Schritt 1 -",
    title2: " Auswahl:",
    text: "Outfit, Produkt, Stilwelt oder Thema wählen.",
  },
  {
    img: "luftschloss-verse.github.io/imgs/Abfrage.png",
    alt: "Selection screen",
    title1: "Schritt 2 -",
    title2: " Konfigurieren:",
    text: "Kombinieren, Foto aufnehmen, Personalisieren, Details anpassen.",
  },
  {
    img: "luftschloss-verse.github.io/imgs/snapshot.png",
    alt: "Confirmation Screen",
    title1: "Schritt 3 -",
    title2: " KI-Inszenierung:",
    text: "Die KI erstellt live ein hochwertiges Bild/Video – optimiert für deine Ästhetik.",
  },
  {
    img: "luftschloss-verse.github.io/imgs/cover.png",
    alt: "Snapshot Camera Screen",
    title1: "Schritt 4 -",
    title2: " Wartezeit-USP",
    text: "Quiz, Signatur, Brand-Story oder Interaktion – keine tote Wartezeit.",
  },
  {
    img: "luftschloss-verse.github.io/imgs/result.png",
    alt: "Resultat Screen",
    title1: "Schritt 5 -",
    title2: " Teilen/Mitnehmen",
    text: "QR-Download, Social Media, oder Print (optional)",
  },
];
---

<BaseLayout>
<!-- HERO -->

<Diashow interval={5000} />

<!-- 
  <section id="project" style="position:relative; min-height: 90vh; overflow:hidden;">
    <img
      src="luftschloss-verse.github.io/imgs/hero.png"
      alt=""
      style="position:absolute; inset:0; height:100%; width: 100%; object-fit:cover; object-position: 50% 40%;"/>

    <div class="hero-title">
      <h1>Create. Select.</br>
         &nbsp;&nbsp;&nbsp;&nbsp;Experience.</br>
        <span style="font-family: Unigeo slim;">- Live mit KI</span></h1>
    </div>

    <div class="name-title">
      <h1>AI-<span style="font-family: Unigeo semibold;">Verse</span><br></h1>

      <div class="lede">
        Schon überlegt, wie du & dein Produkt in <span style="font-weight:800;">einer neuen Dimension</span> wirken?
      </div>
    </div>
  </section>-->

<!-- WHITE BOX -->
  <section class="white-block">
    <div class="white-block_inner">

      <div class="white-card">
        <div class="white-card-title">  
          <span style="font-family: Unigeo semibold Italic;">AI-VERSE</span> ist eine physische Installation<br/>
            mit eigener App.<br/><br/>
        </div>
        <b>Besucher stellen Inhalte wie Outfits, Produkte, Szenen individuell zusammen – die KI
        generiert daraus in Echtzeit ein hochwertiges Ergebnis.</b>
      </div>

      <img
        src="luftschloss-verse.github.io/imgs/points.png"
        alt=""
        class="points-img"
      />

    </div>
  </section>

<!-- Diashow Block -->
  <section id="about" class="section" style="padding-top: 100px;">
    <div style="position:relative; z-index:2;">
      <Slideshow slides={slides} interval={3000} startIndex={0}>
        <Fragment slot="headline">
          <h2 style="padding-bottom: 80px;">So funktioniert's.</br>
          <span style="font-family: Bahnschrift; font-size: 18px; font-weight:300; line-height: 1.5;">
            Eigene App. Gebrandete Stele. Modulares Konzept. Kurze Wartezeiten.
          </span></h2>
        </Fragment>
      </Slideshow>
    </div>
  </section>

  <!-- <div class="hr"></div> -->

  <!-- MODULE -->
<section class="modules">
  <Modules />
</section>

<!-- HIMMEL -->
  <section class="himmel">
  <img class="himmel_bg" src="luftschloss-verse.github.io/imgs/himmel.png" alt="" />
  <div class="himmel_inner">
    <div class="himmel_text">
      <h2 class="himmel_h" style="letter-spacing: 0.02em;">
        Design first. </br>
        <span>Nicht KI first.</span>
      </h2>

      <p class="himmel_p">
        Bei <b>Luftschloss</b> beginnt alles mit Gestaltung.<br />
        Look &amp; Feel, Interface, Bildästhetik und die Stele<br />
        werden im Design deiner Marke entwickelt.<br />
        Das Ergebnis wirkt nicht wie generische KI –<br />
        sondern wie ein <b>echter Teil deiner Markenwelt.</b>
      </p>
    </div>
  </div>

  <div class="himmel_right">
      <div class="himmel_sig">
        <img src="luftschloss-verse.github.io/imgs/sign.png" alt="Signature" />
      </div>

      <div class="orb orb--a">
        <div class="orb_t"><b>Stilwelten</b><br/>kuratiert<br/><span>(nicht zufällig)</span></div>
      </div>

      <div class="orb orb--b">
        <div class="orb_t"><b>UI &amp; Flow</b> im<br/>Corporate<br/>Design</div>
      </div>

      <div class="orb orb--c">
        <div class="orb_t"><b>Stele &amp; Frame</b><br/>gebrandet<br/><span>(physisch sichtbar)</span></div>
      </div>
    </div>
</section>

<!-- COMPARISON BLOCK -->
  <section>
    <Comparison />
  </section>

<!-- AI VERSE -->
<section class="pros">
  <div class="pros_inner">

    <p class="pros_kicker">
      Für den <span>echten Einsatz</span> gebaut.
    </p>

    <div class="pros_logoWrap" aria-label="AI-Verse">
      <div class="pros_gradient" aria-hidden="true"></div>
      <h2 class="pros_logo">
        AI<span style="font-family: Unigeo;">-Verse</span>
      </h2>
    </div>

    <div class="pros_grid" role="list">
      <div class="pros_item" role="listitem">
        <div class="pros_check" aria-hidden="true">✓</div>
        <div class="pros_label">Optimiert für kurze<br/>Wartezeiten</div>
      </div>

      <div class="pros_item" role="listitem">
        <div class="pros_check" aria-hidden="true">✓</div>
        <div class="pros_label">Stabil für Dauerbetrieb<br/>&nbsp;</div>
      </div>

      <div class="pros_item" role="listitem">
        <div class="pros_check" aria-hidden="true">✓</div>
        <div class="pros_label">Vor Ort betreut oder<br/>remote steuerbar</div>
      </div>

      <div class="pros_item" role="listitem">
        <div class="pros_check" aria-hidden="true">✓</div>
        <div class="pros_label">Anpassbar an Raum, Licht,<br/>Publikum</div>
      </div>
    </div>

  </div>
</section>

<!-- ANFRAGE CTA -->
  <section class="white-block">
    <div class="white-block_inner">
      <BlobMask />
      <div class="white-card" style="font-size: 50px; font-family: Unigeo italic; margin-top: -280px;">
          <div>Preis auf Anfrage?<br/>
          <span style="font-family: Unigeo MediumItalic;">Nicht unser Stil.</span><br/></div>

          <div style="font-family: Unigeo;"><br/> ↓ </div>

          <div style="font-family: Bahnschrift; font-size:25px; margin-top: 14px;">Unsere Preise sind transparent - damit <br/>
          du von Anfang an planen kannst.<br/><br/>

          <span style="font-weight: 800;">Luftschloss-Experiences starten ab ... €.<br/>
          und wachsen mit deinen Ideen.</span></div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
